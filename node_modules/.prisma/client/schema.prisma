// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  profile      UserProfile?
  resumes      Resume[]
  applications Application[]
  savedJobs    SavedJob[]

  @@map("users")
}

model UserProfile {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  headline       String?
  summary        String?
  location       String?
  linkedinUrl    String?  @map("linkedin_url")
  githubUrl      String?  @map("github_url")
  portfolioUrl   String?  @map("portfolio_url")
  yearsExp       Int?     @map("years_exp")
  seniorityLevel String?  @map("seniority_level") // junior | mid | senior | lead
  desiredSalary  Int?     @map("desired_salary")
  availableFor   String[] @map("available_for") // ["remote", "hybrid", "onsite"]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills Skill[]

  @@map("user_profiles")
}

model Skill {
  id        String  @id @default(uuid())
  profileId String  @map("profile_id")
  name      String
  level     String  @default("intermediate") // beginner | intermediate | advanced | expert
  yearsExp  Int?    @map("years_exp")
  category  String? // frontend | backend | devops | database | mobile | other

  profile UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("skills")
}

// ─────────────────────────────────────────────
// RESUMES
// ─────────────────────────────────────────────

model Resume {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  isBase    Boolean  @default(false) @map("is_base") // master resume
  content   Json // structured resume data
  rawText   String?  @map("raw_text") @db.Text
  fileUrl   String?  @map("file_url")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("resumes")
}

// ─────────────────────────────────────────────
// JOBS
// ─────────────────────────────────────────────

model Job {
  id             String    @id @default(uuid())
  externalId     String?   @map("external_id")
  sourceUrl      String    @unique @map("source_url")
  source         String // linkedin | gupy | indeed | glassdoor | manual
  title          String
  company        String
  location       String?
  workMode       String?   @map("work_mode") // remote | hybrid | onsite
  contractType   String?   @map("contract_type") // full-time | part-time | contract | freelance
  salaryMin      Int?      @map("salary_min")
  salaryMax      Int?      @map("salary_max")
  description    String    @db.Text
  requirements   String?   @db.Text
  benefits       String?   @db.Text
  requiredSkills String[]  @map("required_skills")
  niceToHave     String[]  @map("nice_to_have")
  seniority      String?
  postedAt       DateTime? @map("posted_at")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  scrapedAt      DateTime  @default(now()) @map("scraped_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  applications Application[]
  savedBy      SavedJob[]
  analyses     JobAnalysis[]

  @@map("jobs")
}

model JobAnalysis {
  id             String   @id @default(uuid())
  jobId          String   @map("job_id")
  userId         String   @map("user_id")
  overallScore   Int      @map("overall_score") // 0-100
  skillScore     Int      @map("skill_score")
  seniorityScore Int      @map("seniority_score")
  cultureScore   Int?     @map("culture_score")
  stackScore     Int      @map("stack_score")
  matchedSkills  String[] @map("matched_skills")
  missingSkills  String[] @map("missing_skills")
  highlights     String[] // what's great about this match
  gaps           String[] // what's missing
  recommendation String // apply | consider | skip
  aiExplanation  String   @map("ai_explanation") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_analyses")
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

// ─────────────────────────────────────────────
// APPLICATIONS
// ─────────────────────────────────────────────

model Application {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  jobId          String            @map("job_id")
  resumeId       String?           @map("resume_id")
  status         ApplicationStatus @default(PENDING)
  tailoredResume Json?             @map("tailored_resume")
  coverLetter    String?           @map("cover_letter") @db.Text
  technicalBrief String?           @map("technical_brief") @db.Text
  appliedAt      DateTime?         @map("applied_at")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // Relations
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job                @relation(fields: [jobId], references: [id])
  resume Resume?            @relation(fields: [resumeId], references: [id])
  events ApplicationEvent[]

  @@map("applications")
}

model ApplicationEvent {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  type          String // viewed | applied | screening | interview | offer | rejected | withdrawn
  description   String?
  occurredAt    DateTime @default(now()) @map("occurred_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_events")
}

// ─────────────────────────────────────────────
// QUEUE JOBS (tracking async jobs)
// ─────────────────────────────────────────────

model QueueJob {
  id        String   @id @default(uuid())
  type      String // scrape | analyze | tailor | apply
  status    String   @default("pending") // pending | processing | done | failed
  payload   Json
  result    Json?
  error     String?
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("queue_jobs")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum ApplicationStatus {
  PENDING
  READY
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}
