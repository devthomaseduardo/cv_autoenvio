# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
# Use docker-compose values: postgres/password@localhost:5432/jobtailor
DATABASE_URL="postgresql://postgres:password@localhost:5432/jobtailor?schema=public"

# Redis (BullMQ / Cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_me
JWT_REFRESH_EXPIRATION=30d

# OpenAI API
# Get your key at https://platform.openai.com/
OPENAI_API_KEY=sk-proj-....

# Security
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Logging
LOG_LEVEL=debug

# Python Automation (New)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# PLAYWRIGHT_BROWSER=chromium

# Seed Data (Optional)
ADMIN_EMAIL=admin@jobtailor.com
ADMIN_PASSWORD=admin_password_123
