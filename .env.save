# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/jobtailor?schema=public"

# Redis (BullMQ / Cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication
JWT_SECRET=jobtailor_secret_key_2024_portfolio
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=jobtailor_refresh_secret_key_2024
JWT_REFRESH_EXPIRATION=30d

# OpenAI API
# Replace with your actual key
OPENAI_API_KEY=sk-placeholder
pip install -q -U google-generativeai
# Security
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Logging
LOG_LEVEL=debug
